{
  "name": "user_admin_can_edit_posts",
  "description": "admin has post:edit and can replace a post",
  "steps": [
    {
      "request": {
        "method": "POST",
        "path": "/v1/login",
        "body": { "email": "admin@example.com", "password": "admin" }
      },
      "expect": { "status": 200 },
      "capture": { "token": ".token" }
    },
    {
      "auth": "{{token}}",
      "request": {
        "method": "POST",
        "path": "/v1/posts",
        "body": { "title": "Draft title", "content": "Draft body" }
      },
      "expect": { "status": 201 },
      "capture": { "post_id": ".id" }
    },
    {
      "auth": "{{token}}",
      "request": {
        "method": "PUT",
        "path": "/v1/posts/{{post_id}}",
        "body": { "title": "Edited title", "content": "Edited body", "status": "published" }
      },
      "expect": {
        "status": 200,
        "jq": [".title == \"Edited title\"", ".status == \"published\""]
      }
    }
  ]
}

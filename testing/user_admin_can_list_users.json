{
  "name": "user_admin_can_list_users",
  "description": "admin has users:read and can list users",
  "steps": [
    {
      "request": {
        "method": "POST",
        "path": "/v1/login",
        "body": {
          "email": "admin@example.com",
          "password": "admin"
        }
      },
      "expect": {
        "status": 200
      },
      "capture": {
        "token": ".token"
      }
    },
    {
      "request": {
        "method": "GET",
        "path": "/v1/users"
      },
      "expect": {
        "status": 200,
        "jq": [
          ".data != null"
        ]
      },
      "auth": "{{token}}"
    }
  ]
}

{
  "name": "user_editor_can_read_others_user",
  "description": "editor has unscoped users:read and can read another user",
  "steps": [
    {
      "request": {
        "method": "POST",
        "path": "/v1/login",
        "body": {
          "email": "admin@example.com",
          "password": "admin"
        }
      },
      "expect": {
        "status": 200
      },
      "capture": {
        "token": ".token"
      }
    },
    {
      "request": {
        "method": "POST",
        "path": "/v1/users",
        "body": {
          "email": "newuser-{{nonce}}@example.com",
          "password": "password123",
          "first_name": "New",
          "last_name": "User",
          "role": "reader"
        }
      },
      "expect": {
        "status": 201
      },
      "auth": "{{token}}",
      "capture": {
        "target_uid": ".id"
      }
    },
    {
      "request": {
        "method": "POST",
        "path": "/v1/login",
        "body": {
          "email": "editor@example.com",
          "password": "editor"
        }
      },
      "expect": {
        "status": 200
      },
      "capture": {
        "token2": ".token"
      }
    },
    {
      "request": {
        "method": "GET",
        "path": "/v1/users/{{target_uid}}"
      },
      "expect": {
        "status": 200,
        "jq": [
          ".id != null"
        ]
      },
      "auth": "{{token2}}"
    }
  ]
}

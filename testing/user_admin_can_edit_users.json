{
  "name": "user_admin_can_edit_users",
  "description": "admin has users:edit and can update a user",
  "steps": [
    {
      "request": {
        "method": "POST",
        "path": "/v1/login",
        "body": {
          "email": "admin@example.com",
          "password": "admin"
        }
      },
      "expect": {
        "status": 200
      },
      "capture": {
        "token": ".token"
      }
    },
    {
      "request": {
        "method": "POST",
        "path": "/v1/users",
        "body": {
          "email": "newuser-{{nonce}}@example.com",
          "password": "password123",
          "first_name": "New",
          "last_name": "User",
          "role": "reader"
        }
      },
      "expect": {
        "status": 201
      },
      "auth": "{{token}}",
      "capture": {
        "nid": ".id"
      }
    },
    {
      "request": {
        "method": "PATCH",
        "path": "/v1/users/{{nid}}",
        "body": {
          "first_name": "Edited"
        }
      },
      "expect": {
        "status": 200,
        "jq": [
          ".first_name == \"Edited\""
        ]
      },
      "auth": "{{token}}"
    }
  ]
}

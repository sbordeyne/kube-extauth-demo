{
  "name": "user_editor_can_create_posts",
  "description": "editor has post:create and can create a post",
  "steps": [
    {
      "request": {
        "method": "POST",
        "path": "/v1/login",
        "body": { "email": "editor@example.com", "password": "editor" }
      },
      "expect": { "status": 200 },
      "capture": { "token": ".token" }
    },
    {
      "auth": "{{token}}",
      "request": {
        "method": "POST",
        "path": "/v1/posts",
        "body": { "title": "Editor post", "content": "Created by editor" }
      },
      "expect": {
        "status": 201,
        "jq": [".id != null", ".title == \"Editor post\""]
      }
    }
  ]
}

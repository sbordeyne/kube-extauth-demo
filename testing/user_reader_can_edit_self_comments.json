{
  "name": "user_reader_can_edit_self_comments",
  "description": "reader has comment:edit:me and can edit its own comment",
  "steps": [
    {
      "request": {
        "method": "POST",
        "path": "/v1/login",
        "body": { "email": "admin@example.com", "password": "admin" }
      },
      "expect": { "status": 200 },
      "capture": { "token": ".token" }
    },
    {
      "auth": "{{token}}",
      "request": {
        "method": "POST",
        "path": "/v1/posts",
        "body": { "title": "Post", "content": "body" }
      },
      "expect": { "status": 201 },
      "capture": { "post_id": ".id" }
    },
    {
      "request": {
        "method": "POST",
        "path": "/v1/login",
        "body": { "email": "reader@example.com", "password": "reader" }
      },
      "expect": { "status": 200 },
      "capture": { "token2": ".token" }
    },
    {
      "auth": "{{token2}}",
      "request": {
        "method": "POST",
        "path": "/v1/posts/{{post_id}}/comments",
        "body": { "content": "reader original" }
      },
      "expect": { "status": 201 },
      "capture": { "comment_id": ".id" }
    },
    {
      "auth": "{{token2}}",
      "request": {
        "method": "PUT",
        "path": "/v1/posts/{{post_id}}/comments/{{comment_id}}",
        "body": { "content": "reader edited own" }
      },
      "expect": {
        "status": 200,
        "jq": [".content == \"reader edited own\""]
      }
    }
  ]
}

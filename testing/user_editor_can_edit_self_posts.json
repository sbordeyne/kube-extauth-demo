{
  "name": "user_editor_can_edit_self_posts",
  "description": "editor has post:edit:me and can replace its own post",
  "steps": [
    {
      "request": {
        "method": "POST",
        "path": "/v1/login",
        "body": {
          "email": "editor@example.com",
          "password": "editor"
        }
      },
      "expect": {
        "status": 200
      },
      "capture": {
        "token": ".token"
      }
    },
    {
      "request": {
        "method": "POST",
        "path": "/v1/posts",
        "body": {
          "title": "Scenario post",
          "content": "body"
        }
      },
      "expect": {
        "status": 201
      },
      "auth": "{{token}}",
      "capture": {
        "post_id": ".id"
      }
    },
    {
      "request": {
        "method": "PUT",
        "path": "/v1/posts/{{post_id}}",
        "body": {
          "title": "Editor edit",
          "content": "x"
        }
      },
      "expect": {
        "status": 200,
        "jq": [
          ".title == \"Editor edit\""
        ]
      },
      "auth": "{{token}}"
    }
  ]
}

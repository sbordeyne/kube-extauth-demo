{
  "name": "user_reader_can_login",
  "description": "reader logs in and receives a bearer token",
  "steps": [
    {
      "request": {
        "method": "POST",
        "path": "/v1/login",
        "body": { "email": "reader@example.com", "password": "reader" }
      },
      "expect": {
        "status": 200,
        "jq": [".token != null and (.token | length) > 0", ".token_type == \"bearer\"", ".user.role.slug == \"reader\""]
      }
    }
  ]
}

{
  "name": "user_admin_can_edit_others_comments",
  "description": "admin has unscoped comment:edit — editor writes a comment, admin edits it",
  "steps": [
    {
      "request": {
        "method": "POST",
        "path": "/v1/login",
        "body": { "email": "admin@example.com", "password": "admin" }
      },
      "expect": { "status": 200 },
      "capture": { "token": ".token" }
    },
    {
      "auth": "{{token}}",
      "request": {
        "method": "POST",
        "path": "/v1/posts",
        "body": { "title": "Shared post", "content": "body" }
      },
      "expect": { "status": 201 },
      "capture": { "post_id": ".id" }
    },
    {
      "request": {
        "method": "POST",
        "path": "/v1/login",
        "body": { "email": "editor@example.com", "password": "editor" }
      },
      "expect": { "status": 200 },
      "capture": { "token2": ".token" }
    },
    {
      "auth": "{{token2}}",
      "request": {
        "method": "POST",
        "path": "/v1/posts/{{post_id}}/comments",
        "body": { "content": "editor's comment" }
      },
      "expect": { "status": 201 },
      "capture": { "comment_id": ".id" }
    },
    {
      "auth": "{{token}}",
      "request": {
        "method": "PUT",
        "path": "/v1/posts/{{post_id}}/comments/{{comment_id}}",
        "body": { "content": "edited by admin" }
      },
      "expect": {
        "status": 200,
        "jq": [".content == \"edited by admin\""]
      }
    }
  ]
}

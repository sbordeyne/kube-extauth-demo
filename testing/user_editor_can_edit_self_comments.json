{
  "name": "user_editor_can_edit_self_comments",
  "description": "editor has comment:edit:me and can edit its own comment",
  "steps": [
    {
      "request": {
        "method": "POST",
        "path": "/v1/login",
        "body": {
          "email": "admin@example.com",
          "password": "admin"
        }
      },
      "expect": {
        "status": 200
      },
      "capture": {
        "token": ".token"
      }
    },
    {
      "request": {
        "method": "POST",
        "path": "/v1/posts",
        "body": {
          "title": "Scenario post",
          "content": "body"
        }
      },
      "expect": {
        "status": 201
      },
      "auth": "{{token}}",
      "capture": {
        "post_id": ".id"
      }
    },
    {
      "request": {
        "method": "POST",
        "path": "/v1/login",
        "body": {
          "email": "editor@example.com",
          "password": "editor"
        }
      },
      "expect": {
        "status": 200
      },
      "capture": {
        "token2": ".token"
      }
    },
    {
      "request": {
        "method": "POST",
        "path": "/v1/posts/{{post_id}}/comments",
        "body": {
          "content": "a comment"
        }
      },
      "expect": {
        "status": 201
      },
      "auth": "{{token2}}",
      "capture": {
        "comment_id": ".id"
      }
    },
    {
      "request": {
        "method": "PUT",
        "path": "/v1/posts/{{post_id}}/comments/{{comment_id}}",
        "body": {
          "content": "editor edited own"
        }
      },
      "expect": {
        "status": 200,
        "jq": [
          ".content == \"editor edited own\""
        ]
      },
      "auth": "{{token2}}"
    }
  ]
}

{
  "name": "user_admin_can_delete_others_comments",
  "description": "admin has unscoped comment:delete \u2014 editor comments, admin deletes it",
  "steps": [
    {
      "request": {
        "method": "POST",
        "path": "/v1/login",
        "body": {
          "email": "admin@example.com",
          "password": "admin"
        }
      },
      "expect": {
        "status": 200
      },
      "capture": {
        "token": ".token"
      }
    },
    {
      "request": {
        "method": "POST",
        "path": "/v1/posts",
        "body": {
          "title": "Scenario post",
          "content": "body"
        }
      },
      "expect": {
        "status": 201
      },
      "auth": "{{token}}",
      "capture": {
        "post_id": ".id"
      }
    },
    {
      "request": {
        "method": "POST",
        "path": "/v1/login",
        "body": {
          "email": "editor@example.com",
          "password": "editor"
        }
      },
      "expect": {
        "status": 200
      },
      "capture": {
        "token2": ".token"
      }
    },
    {
      "request": {
        "method": "POST",
        "path": "/v1/posts/{{post_id}}/comments",
        "body": {
          "content": "a comment"
        }
      },
      "expect": {
        "status": 201
      },
      "auth": "{{token2}}",
      "capture": {
        "comment_id": ".id"
      }
    },
    {
      "request": {
        "method": "DELETE",
        "path": "/v1/posts/{{post_id}}/comments/{{comment_id}}"
      },
      "expect": {
        "status": 204
      },
      "auth": "{{token}}"
    }
  ]
}

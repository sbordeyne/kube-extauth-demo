{
  "name": "user_reader_can_create_comments",
  "description": "reader has comment:create and can comment on a post",
  "steps": [
    {
      "request": {
        "method": "POST",
        "path": "/v1/login",
        "body": { "email": "admin@example.com", "password": "admin" }
      },
      "expect": { "status": 200 },
      "capture": { "token": ".token" }
    },
    {
      "auth": "{{token}}",
      "request": {
        "method": "POST",
        "path": "/v1/posts",
        "body": { "title": "Post for reader comment", "content": "body" }
      },
      "expect": { "status": 201 },
      "capture": { "post_id": ".id" }
    },
    {
      "request": {
        "method": "POST",
        "path": "/v1/login",
        "body": { "email": "reader@example.com", "password": "reader" }
      },
      "expect": { "status": 200 },
      "capture": { "token2": ".token" }
    },
    {
      "auth": "{{token2}}",
      "request": {
        "method": "POST",
        "path": "/v1/posts/{{post_id}}/comments",
        "body": { "content": "reader comment" }
      },
      "expect": {
        "status": 201,
        "jq": [".id != null", ".content == \"reader comment\""]
      }
    }
  ]
}

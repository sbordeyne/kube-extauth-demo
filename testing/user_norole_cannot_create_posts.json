{
  "name": "user_norole_cannot_create_posts",
  "description": "norole has no scopes \u2014 creating a post must be forbidden (expects 403)",
  "steps": [
    {
      "request": {
        "method": "POST",
        "path": "/v1/login",
        "body": {
          "email": "norole@example.com",
          "password": "norole"
        }
      },
      "expect": {
        "status": 200
      },
      "capture": {
        "token": ".token"
      }
    },
    {
      "request": {
        "method": "POST",
        "path": "/v1/posts",
        "body": {
          "title": "Scenario post",
          "content": "body"
        }
      },
      "expect": {
        "status": 403
      },
      "auth": "{{token}}"
    }
  ]
}

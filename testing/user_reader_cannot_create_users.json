{
  "name": "user_reader_cannot_create_users",
  "description": "reader lacks users:create \u2014 creating a user must be forbidden (expects 403)",
  "steps": [
    {
      "request": {
        "method": "POST",
        "path": "/v1/login",
        "body": {
          "email": "reader@example.com",
          "password": "reader"
        }
      },
      "expect": {
        "status": 200
      },
      "capture": {
        "token": ".token"
      }
    },
    {
      "request": {
        "method": "POST",
        "path": "/v1/users",
        "body": {
          "email": "newuser-{{nonce}}@example.com",
          "password": "password123",
          "first_name": "New",
          "last_name": "User",
          "role": "reader"
        }
      },
      "expect": {
        "status": 403
      },
      "auth": "{{token}}"
    }
  ]
}
